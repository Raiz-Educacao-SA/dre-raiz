{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/agent-team/run-scheduled",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/inquiry-sla-check",
      "schedule": "0 * * * *"
    }
  ]
}
